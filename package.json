{
  "name": "@deneuv34/sensei",
  "version": "0.4.0",
  "description": "Before your AI agent writes code, Sensei tells it what already exists, what to reuse, and what not to touch.",
  "type": "module",
  "license": "MIT",
  "author": "Rangga Adhitya",
  "homepage": "https://github.com/deneuv34/sensei#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deneuv34/sensei.git"
  },
  "bugs": {
    "url": "https://github.com/deneuv34/sensei/issues"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "code-context",
    "code-reuse",
    "duplicate-detection",
    "static-analysis",
    "typescript",
    "javascript",
    "cli",
    "llm",
    "codegen",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "sensei": "bin/run.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "better-sqlite3": "^12.10.1",
    "fast-glob": "^3.3.0",
    "ignore": "^6.0.0",
    "listr2": "^10.2.1",
    "simple-git": "^3.25.0",
    "typescript": "^6.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "vitest": "^4.1.9"
  },
  "oclif": {
    "bin": "sensei",
    "dirname": "sensei",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
